    "@hey-api/client-fetch": "^0.13.1",
    "@mastra/ai-sdk": "^1.0.0",
    "@mastra/core": "^1.13.2",
    "@mastra/loggers": "^1.0.0",
    "@mastra/memory": "^1.0.0",
    "@mastra/observability": "^1.0.0",
    "@mastra/pg": "^1.0.0",
    "@mastra/s3": "^0.2.1",
    "@nixopus/api-client": "0.0.16",
    "@openrouter/ai-sdk-provider": "^2.3.0",
    "@toon-format/toon": "^2.1.0",
