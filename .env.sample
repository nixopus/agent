NODE_ENV=development
HOST=0.0.0.0
PORT=9090

SELF_HOSTED=false

DATABASE_URL=postgresql://username:password@localhost:5432/dbname?sslmode=disable
REDIS_URL=redis://localhost:6379

# LLM Provider Configuration
#
# By default, the agent uses OpenRouter. Set OPENROUTER_API_KEY to enable it.
# Or override AGENT_MODEL / AGENT_LIGHT_MODEL explicitly for any provider.
#
# OpenRouter (default):
#   OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# OpenAI:
#   OPENAI_API_KEY=sk-xxxxxxxx
#   AGENT_MODEL=openai/gpt-4o
#   AGENT_LIGHT_MODEL=openai/gpt-4o-mini
#
# Anthropic:
#   ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
#   AGENT_MODEL=anthropic/claude-sonnet-4
#   AGENT_LIGHT_MODEL=anthropic/claude-haiku-3.5
#
# Google Gemini:
#   GOOGLE_GENERATIVE_AI_API_KEY=xxxxxxxx
#   AGENT_MODEL=google/gemini-2.5-flash
#   AGENT_LIGHT_MODEL=google/gemini-2.0-flash
#
# DeepSeek:
#   DEEPSEEK_API_KEY=sk-xxxxxxxx
#   AGENT_MODEL=deepseek/deepseek-chat
#   AGENT_LIGHT_MODEL=deepseek/deepseek-chat
#
# Groq:
#   GROQ_API_KEY=gsk_xxxxxxxx
#   AGENT_MODEL=groq/llama-3.3-70b-versatile
#   AGENT_LIGHT_MODEL=groq/llama-3.3-70b-versatile

AUTH_SERVICE_URL=http://localhost:9090
INTERNAL_CRON_SECRET=your_random_secret_here
M2M_CLIENT_ID=your_client_id
M2M_CLIENT_SECRET=your_client_secret

LOG_LEVEL=info
LOG_NAME=Mastra
OBSERVABILITY_ENABLED=true

S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://your-s3-endpoint
